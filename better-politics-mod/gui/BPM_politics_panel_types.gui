					# 		using = default_hide_properties_fast
					# 	}
					# }

					widget = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding
					}
				}

				law_changable_widget = {}
			}
		}
	}

	
	type laws_list = vbox {
		layoutpolicy_horizontal = preferred
		layoutpolicy_vertical = preferred
		layoutstretchfactor_horizontal = 1

		using = entry_bg_fancy

		widget = {
			layoutpolicy_horizontal = preferred
			tooltip = "ACTIVE_LAWS_DESC"
			size = { 0 38 }

			background = {
				using = default_header_bg
				using = frame_small_mask_top
			}

			textbox = {
				block "header" {
					raw_text = "INSERT_HEADER"
				}
				size = { 100% 100% }
				align = center|nobaseline
				using = fontsize_large
				default_format = "#title"
				elide = right
			}
		}

		vbox = {
			layoutpolicy_horizontal = preferred
			layoutpolicy_vertical = preferred
			block "law_datamodel" {
			}

			item = {
				vbox = {
					margin = { 10 2 }
					layoutpolicy_horizontal = preferred
					layoutpolicy_vertical = expanding
					widgetid = "[Law.GetGroup.GetKey]"

					background = {
						visible = "[Law.IsBeingEnacted]"
						using = highlighted_square_selection
						margin = { -7 0 }
						margin_top = 0
					}

					active_law = {
						visible = "[Not(Law.IsBeingEnacted)]"
					}

					enacting_law = {
						visible = "[Law.IsBeingEnacted]"
					}
				}
			}
		}
		widget = {
			layoutpolicy_horizontal = preferred
			layoutpolicy_vertical = expanding
		}
	}

	### AMENDMENT FLOWCONTAINER
	type amendment_flowcontainer = flowcontainer {
		direction = vertical
		using = tooltip_se
		using = entry_bg_fancy_solid_bg

		tooltipwidget = {
			FancyTooltip_Amendment = {}
		}

		container = {
			block "header_minimumsize" {
				minimumsize = { 500 40 }
			}

			background = {
				using = fade_right_colored
				using = frame_small_mask
				color = "[Amendment.GetSponsor.GetColor]"
			}

			flowcontainer = {
				parentanchor = vcenter
				position = { 7 0 }
				spacing = 5

				icon = {
					datacontext = "[Amendment.GetParentLawType]"
					size = { 30 30 }
					texture = "[LawType.GetTexture]"
				}

				textbox = {
					parentanchor = vcenter
					autoresize = yes
					align = nobaseline
					fontsize_min = 14
					elide = right
					text = "[Amendment.GetNameNoFormatting]"
				}

				icon = {
					datacontext = "[Amendment.GetSponsor]"
					size = { 30 30 }
					texture = "[InterestGroup.GetTexture]"
				}
			}

			flowcontainer = {
				parentanchor = vcenter|right
				spacing = 15
				position = { -7 0 }

				textbox = {
					parentanchor = vcenter
					autoresize = yes
					align = nobaseline
					elide = right
					using = fontsize_small
					text = "[concept_amendment]"
				}

				button_icon_cancel = {
					size = { 30 30 }
					enabled = "[GetScriptedGui('bpm_repeal_amendment_confirmation_gui').IsValid(GuiScope.SetRoot(Country.MakeScope).AddScope('at', Amendment.MakeScope).End)]"
					onclick = "[GetScriptedGui('bpm_repeal_amendment_confirmation_gui').Execute(GuiScope.SetRoot(Country.MakeScope).AddScope('at', Amendment.MakeScope).End)]"
					onclick = "[InformationPanelBar.OpenPanelTab( 'politics', 'interest_groups' )]"
					using = close_button_sound
					tooltip = "[GetScriptedGui('bpm_repeal_amendment_confirmation_gui').ExecuteTooltip(GuiScope.SetRoot(Country.MakeScope).AddScope('at', Amendment.MakeScope).End)]"
				}

			}
		}

		flowcontainer = {
			direction = vertical
			margin = { 10 3 }

			block "effects_and_modifiers_visibility" {
				visible = no
			}

			textbox = {
				visible = "[Not(StringIsEmpty(Amendment.GetType.GetSponsorModifier.GetDesc))]"
				autoresize = yes
				align = nobaseline
				min_width = 500
				max_width = 500
				multiline = yes
				text = "DATA_AMENDMENTS_SPONSOR_MODIFIERS_HEADER"
			}

			textbox = {
				visible = "[Not(StringIsEmpty(Amendment.GetType.GetSponsorModifier.GetDesc))]"
				autoresize = yes
				align = nobaseline
				min_width = 500
				max_width = 500
				multiline = yes
				text = "[Amendment.GetType.GetSponsorModifier.GetDesc]"
			}

			textbox = {
				visible = "[Not(StringIsEmpty(Amendment.GetType.GetModifier.GetDesc))]"
				autoresize = yes
				align = nobaseline
				min_width = 500
				max_width = 500
				multiline = yes
				text = "DATA_AMENDMENTS_MODIFIERS_HEADER"
			}

			textbox = {
				visible = "[Not(StringIsEmpty(Amendment.GetType.GetModifier.GetDesc))]"
				autoresize = yes
				align = nobaseline
				min_width = 500
				max_width = 500
				multiline = yes
				text = "[Amendment.GetType.GetModifier.GetDesc]"
			}

			textbox = {
				visible = "[Not(StringIsEmpty(Amendment.GetType.GetTaxModifierDesc(GetPlayer.Self)))]"
				autoresize = yes
				align = nobaseline
				min_width = 500
				max_width = 500
				multiline = yes
				text = "[Amendment.GetType.GetTaxModifierDesc(GetPlayer.Self)]"
			}

			textbox = {
				visible = "[Not(StringIsEmpty(Amendment.GetType.GetInstitutionModifierDesc))]"
				autoresize = yes
				align = nobaseline
				min_width = 500
				max_width = 500
				multiline = yes
				text = "[Amendment.GetType.GetInstitutionModifierDesc]"
			}

			textbox = {
				visible = "[Not(StringIsEmpty(Amendment.GetType.GetUnlocks))]"
				autoresize = yes
				align = nobaseline
				min_width = 500
				max_width = 500
				multiline = yes
				text = "[Amendment.GetType.GetUnlocks]"
			}

			textbox = {
				visible = "[Not(StringIsEmpty(Amendment.GetOnAmendedEffectsDesc))]"
				autoresize = yes
				align = nobaseline
				min_width = 500
				max_width = 500
				multiline = yes
