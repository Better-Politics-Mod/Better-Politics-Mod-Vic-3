types politics_panel_types
{
	type institution_icon = widget {
		size = { 60 60 }
		
		icon = {
			size = { 100% 100% }
			texture = "gfx/interface/icons/institution_icons/institution_icon_bg.dds"
		}
		icon = {
			size = { 100% 100% }
			texture = "[Institution.GetIcon]"
		}
	}
	
	type bpm_cabinet_ig_selection_panel = vbox {
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = expanding
		using = default_fade_in_out

		parentanchor = top

		hbox = {
			margin = { 0 10 }
			button = {
				size = { 300 35 }
				using = default_button_primary
				onclick = "[GetScriptedGui('bpm_CAB_toggle_char_select_off').Execute(GuiScope.SetRoot(Country.MakeScope).End)]"
				using = back_button_sound

				textbox = {
					size = { 100% 100% }
					text = "CANCEL"
					using = fontsize_large
					align = center|nobaseline
				}
			}
		}

		# vbox = {
		# 	# layoutpolicy_horizontal = preferred
		# 	# layoutpolicy_vertical = expanding
		# 	background = {
		# 		using = entry_bg_simple
		# 	}
		# 	textbox = {
		# 		# layoutpolicy_vertical = preferred
		# 		size = { 500 50 }
		# 		text = "bpm_mandate_overall_text"
		# 		using = fontsize_large
		# 		align = center|nobaseline
		# 	}
		# }
		
		vbox = {
			# parentanchor = left
			#datamodel_wrap = 3
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			spacing = 5
			margin = { 20 10 }

			flowcontainer = {
				dynamicgridbox = {
					#add_row = 100
					#add_column = 50%
					layoutpolicy_horizontal = expanding
					name = "bpm_cabinet_char_select_pool"
					#layoutpolicy_vertical = growing
					datamodel_wrap = 3
					flipdirection = yes
					parentanchor = left
					datamodel = "[GetPlayer.MakeScope.GetList('bpm_potential_characters')]"
					item = {
						container = {
							bpm_cabinet_pool_item = {}
						}
					}
				}
			}
		}

		vbox = {
			layoutpolicy_vertical = expanding
			minimumsize = { -1 330 }
		}
		expand = {}
	}

	type bpm_prime_minister_selection_panel = vbox {
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = expanding
		using = default_fade_in_out

		parentanchor = top

		hbox = {
			margin = { 0 10 }
			button = {
				size = { 300 35 }
				using = default_button_primary
				onclick = "[GetScriptedGui('bpm_CAB_toggle_char_select_off').Execute(GuiScope.SetRoot(Country.MakeScope).End)]"
				using = back_button_sound

				textbox = {
					size = { 100% 100% }
					text = "CANCEL"
					using = fontsize_large
					align = center|nobaseline
				}
			}
		}

		# vbox = {
		# 	# layoutpolicy_horizontal = preferred
		# 	# layoutpolicy_vertical = expanding
		# 	background = {
		# 		using = entry_bg_simple
		# 	}
		# 	textbox = {
		# 		# layoutpolicy_vertical = preferred
		# 		size = { 500 50 }
		# 		text = "bpm_mandate_overall_text"
		# 		using = fontsize_large
		# 		align = center|nobaseline
		# 	}
		# 	textbox = {
		# 		# layoutpolicy_vertical = preferred
		# 		size = { 800 120 }
		# 		text = "bpm_mandate_overall_desc"
		# 		using = fontsize_medium
		# 		align = center|nobaseline
		# 		multiline = yes
		# 	}
		# }
		
		vbox = {
			# parentanchor = left
			#datamodel_wrap = 3
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			spacing = 5
			margin = { 20 10 }

			flowcontainer = {
				dynamicgridbox = {
					#add_row = 100
					#add_column = 50%
					layoutpolicy_horizontal = expanding
					name = "bpm_cabinet_pm_select_pool"
					#layoutpolicy_vertical = growing
					datamodel_wrap = 2
					flipdirection = yes
					parentanchor = left
					datamodel = "[GetPlayer.MakeScope.GetList('bpm_CAB_pm_select_pool')]"
					item = {
						container = {
							bpm_prime_minister_candidate_entry = {}
						}
					}
				}
			}
		}
		vbox = {
			layoutpolicy_vertical = expanding
			minimumsize = { -1 330 }
		}
		expand = {}
	}

