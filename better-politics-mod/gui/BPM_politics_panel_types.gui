						spacing = 2

						icon = {
							size = { 40 40 }
							texture = "gfx/interface/icons/political_movement_icons/movement_ideological.dds"
						}


						textbox = {
							layoutpolicy_horizontal = expanding
							size = { 0 20 }
							align = nobaseline
							elide = right
							fontsize_min = 12
							raw_text = "Unaligned Faction"	
						}
					}
					hbox = {
						layoutpolicy_horizontal = expanding
						margin_left = 10
						spacing = 2

						icon = {
							size = { 25 25 }
							texture = "gfx/interface/icons/generic_icons/government_building_icon.dds"
						}

						textbox = {
							layoutpolicy_horizontal = expanding
							size = { 0 20 }
							align = nobaseline
							elide = right
							fontsize_min = 12
							raw_text = "#v [InterestGroup.MakeScope.ScriptValue('bpm_unaligned_clout')|%1]#!"	
						}
					}
					expand = {}

					hbox = {
						layoutpolicy_horizontal = expanding
						margin_right = 10

						block "right_text_max_width" {
							max_width = 135
						}

