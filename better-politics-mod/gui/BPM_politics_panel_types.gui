					autoresize = yes
					align = nobaseline
					multiline = yes
					text = "DATA_AMENDMENTS_AMENDED_HEADER"

					block "effects_min_max_widths" {
						min_width = 550
						max_width = 550
					}
				}

				textbox = {
					visible = "[Not(StringIsEmpty(Amendment.GetOnAmendedEffectsDesc))]"
					autoresize = yes
					align = nobaseline
					multiline = yes
					margin_left = 10
					text = "[Amendment.GetOnAmendedEffectsDesc]"

					block "effects_min_max_widths" {
