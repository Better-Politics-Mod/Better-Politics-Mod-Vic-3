types politics_panel_types
{
	type politics_panel = fullscreen_block_window {
		name = "politics_panel"

		blockoverride "back_button_fullscreen" {
			back_button_large = {
				visible = "[Not(GetVariableSystem.Exists('politics_overview_exile_pool'))]"
				position = { 11 15 }
				parentanchor = top|left
				onclick = "[InformationPanelBar.OpenPreviousPanel]"
				input_action = "back"
			}

			back_button_large = {
				visible = "[GetVariableSystem.Exists('politics_overview_exile_pool')]"
				position = { 11 15 }
				parentanchor = top|left
				onclick = "[GetVariableSystem.Clear('politics_overview_exile_pool')]"
				input_action = "back"
			}
		}

		blockoverride "animation_state_block" {
			state = {
				name = _show
				start_sound = {
					soundeffect = "event:/SFX/UI/SideBar/politics"
				}
				start_sound = {
					soundeffect = "snapshot:/Dynamic/mute_world_80"
				}
				start_sound = {
					soundeffect = "snapshot:/Dynamic/mute_vfx_war_100"

				}
			}

			state = {
				name = _hide
				start_sound = {
					soundeffect = "event:/SFX/UI/SideBar/politics_stop"
				}
			}
		}

		blockoverride "window_header_name"
		{
			text = "POLITICS_PANEL_HEADER"
		}

		blockoverride "fixed_top"
		{
			tab_buttons = {
				blockoverride "first_button" {
					text = "OVERVIEW"
				}
				blockoverride "first_button_tooltip" {
					tooltip = "OVERVIEW"
				}
				blockoverride "first_button_click" {
					onclick = "[InformationPanel.SelectTab('default')]"
				}
				blockoverride "first_button_visibility" {
					visible = "[InformationPanel.IsTabSelected('default')]"
				}
				blockoverride "first_button_visibility_checked" {
					visible = "[Not( InformationPanel.IsTabSelected('default') )]"
				}
				blockoverride "first_button_selected" {
					text = "OVERVIEW"
				}
				blockoverride "first_button_name" {
					name = "tutorial_highlight_politics_tab"
				}

				blockoverride "second_button" {
					text = "GOVERNMENT"
				}
				blockoverride "second_button_tooltip" {
					tooltip = "GOVERNMENT"
				}
				blockoverride "second_button_click" {
					onclick = "[InformationPanel.SelectTab('interest_groups')]"
				}
				blockoverride "second_button_visibility" {
					visible = "[InformationPanel.IsTabSelected('interest_groups')]"
				}
				blockoverride "second_button_visibility_checked" {
					visible = "[Not( InformationPanel.IsTabSelected('interest_groups') )]"
				}
				blockoverride "second_button_selected" {
					text = "GOVERNMENT"
				}
				blockoverride "second_button_name" {
					name = "tutorial_highlight_interest_groups_tab"
				}

                blockoverride "third_button" {
					text = "ENACTMENT"
				}
				blockoverride "third_button_tooltip" {
					tooltip = "ENACTMENT"
				}
				blockoverride "third_button_click" {
					onclick = "[InformationPanel.SelectTab('enactment')]"
				}
				blockoverride "third_button_visibility" {
					visible = "[InformationPanel.IsTabSelected('enactment')]"
				}
				blockoverride "third_button_visibility_checked" {
					visible = "[Not( InformationPanel.IsTabSelected('enactment') )]"
				}
				blockoverride "third_button_selected" {
					text = "ENACTMENT"
				}
				blockoverride "third_button_name" {
					name = "tutorial_highlight_laws_tab"
				}

				blockoverride "fourth_button" {
					text = "LAWS"
				}
				blockoverride "fourth_button_tooltip" {
					tooltip = "LAWS"
				}
				blockoverride "fourth_button_click" {
					onclick = "[InformationPanel.SelectTab('laws')]"
				}
				blockoverride "fourth_button_visibility" {
					visible = "[InformationPanel.IsTabSelected('laws')]"
				}
				blockoverride "fourth_button_visibility_checked" {
					visible = "[Not( InformationPanel.IsTabSelected('laws') )]"
				}
				blockoverride "fourth_button_selected" {
					text = "LAWS"
				}
				blockoverride "fourth_button_name" {
					name = "tutorial_highlight_laws_tab"
				}

				blockoverride "fifth_button" {
					text = "INSTITUTIONS"
				}
				blockoverride "fifth_button_tooltip" {
					tooltip = "INSTITUTIONS"
				}
				blockoverride "fifth_button_click" {
					onclick = "[InformationPanel.SelectTab('institutions')]"
				}
				blockoverride "fifth_button_visibility" {
					visible = "[InformationPanel.IsTabSelected('institutions')]"
				}
				blockoverride "fifth_button_visibility_checked" {
					visible = "[Not( InformationPanel.IsTabSelected('institutions') )]"
				}
				blockoverride "fifth_button_selected" {
					text = "INSTITUTIONS"
				}
				blockoverride "fifth_button_name" {
					name = "tutorial_highlight_institutions_tab"
				}
			}
		}

		blockoverride "entire_content_area" {

			politics_panel_overview_content = {
				visible = "[InformationPanel.IsTabSelected('default')]"
				using = default_fade_in_out
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
			}

			politics_panel_government = {
				visible = "[InformationPanel.IsTabSelected('interest_groups')]"
				using = default_fade_in_out
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
			}
            

            fullscreen_scrollarea = {
				visible = "[InformationPanel.IsTabSelected('enactment')]"
				state = {
					name = _show
					trigger_on_create = yes
					on_finish = "[GetScriptedGui('enactment_update_law_sides').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
				}
				using = default_fade_in_out
				blockoverride "scrollarea_content" {
					bpm_enactment_panel_content = {
						visible = "[GetPlayer.IsEnactingLaw]"
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding
					}
				}
			}

			fullscreen_scrollarea = {
				visible = "[InformationPanel.IsTabSelected('laws')]"
				using = default_fade_in_out
				blockoverride "scrollarea_content" {
					politics_panel_laws_content = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding
					}
				}
			}

			fullscreen_scrollarea = {
				visible = "[InformationPanel.IsTabSelected('institutions')]"
				using = default_fade_in_out
				blockoverride "scrollarea_content" {
					politics_panel_institutions_content = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding
					}
				}
			}
		}

		### LAWS SEARCH RESULTS (floating above content)
		search_bar_results = {
			parentanchor = top
			position = { 806 265 }
			visible = "[InformationPanel.IsTabSelected('laws')]"
			datacontext = "[PoliticsPanel.GetSearchBar]"

			blockoverride "result_tooltip" {
				visible = "[Not(StringIsEmpty(SearchResult.GetKey))]"
				datacontext = "[GetLawType(SearchResult.GetKey)]"
				tooltipwidget = {
					FancyTooltip_LawType = {}
				}
			}
		}
	}

    type bpm_enactment_panel_content = vbox {
		margin = { 10 10 }
		spacing = 15
		bpm_law_enactment_banner = {}
		hbox = {
		layoutpolicy_horizontal = expanding
		
		vbox = {
			size = { 560 274 }
			layoutpolicy_vertical = expanding
			widget = {
				size = { 556 274 }
				parentanchor = hcenter

				### OVERVIEW BACKGROUND
				background = {
					texture = "gfx/interface/power_blocs/backgrounds/pb_background_generic.dds"
					using = fade_top_illus
				}

				background = {
					using = simple_frame
				}

				### CHARACTERS
				# BLOC MEMBER 4
				# MEMBER AVAILABLE
				container = {
					tooltipwidget = {
						FancyTooltip_Character = {}
					}
					visible = "[GetPlayer.MakeScope.Var('bpm_sup_ig_3').IsSet]"
					datacontext = "[GetPlayer.MakeScope.Var('bpm_sup_ig_3').GetInterestGroup.GetLeader]"
					parentanchor = hcenter
					position = { -210 15 }
					maximumsize = { 100 265 } # This maximumsize is to make the button for this portrait not overlap the other character's buttons

					character_portrait_base = {
						parentanchor = hcenter

						size = { 250 270 }

						blockoverride "portrait_size" {
							block "character_portrait_size" {
								size = { 265 265 }
							}
						}

						blockoverride "portrait_texture" {
							portrait_texture = "[Character.GetAnimatedPortrait('characters_portrait_environment', 'camera_event_right', 'commander_vs_left', PdxGetWidgetScreenSize(PdxGuiWidget.Self))]"
						}

						blockoverride "portrait_icons" {}
						blockoverride "tooltip" {}
						blockoverride "show_hat" {}
						blockoverride "highlight" {}

						blockoverride "portrait_button" {
							button = {
								parentanchor = hcenter
								size = { 100% 100% }

								block "portrait_button_onclick" {
									onclick = "[InformationPanelBar.OpenCharacterPanel(Character.AccessSelf)]"
								}

								block "portrait_button_onrightclick" {
									onrightclick = "[RightClickMenuManager.ShowForCharacter(Character.AccessSelf)]"
								}
							}
						}
					}
				}

				### BLOC MEMBER 2
				# MEMBER AVAILABLE
				container = {
					tooltipwidget = {
						FancyTooltip_Character = {}
					}
					visible = "[GetPlayer.MakeScope.Var('bpm_sup_ig_1').IsSet]"
					datacontext = "[GetPlayer.MakeScope.Var('bpm_sup_ig_1').GetInterestGroup.GetLeader]"
					parentanchor = hcenter
					position = { -110 15 }
					maximumsize = { 100 265 } # This maximumsize is to make the button for this portrait not overlap the other character's buttons

					character_portrait_base = {
						parentanchor = hcenter

						size = { 250 265 }

						blockoverride "portrait_size" {
							block "character_portrait_size" {
								size = { 280 280 }
							}
						}

						blockoverride "portrait_texture" {
							portrait_texture = "[Character.GetAnimatedPortrait('characters_portrait_environment', 'camera_event_right', 'commander_vs_left', PdxGetWidgetScreenSize(PdxGuiWidget.Self))]"
						}

						blockoverride "portrait_mask" {
							mask = "gfx/interface/portraits/portrait_mask_small_fade_bottom.dds"
						}

						blockoverride "portrait_icons" {}
						blockoverride "tooltip" {}
						blockoverride "show_hat" {}
						blockoverride "highlight" {}

						blockoverride "portrait_button" {
							button = {
								parentanchor = hcenter
								size = { 100% 100% }

								block "portrait_button_onclick" {
									onclick = "[InformationPanelBar.OpenCharacterPanel(Character.AccessSelf)]"
								}

								block "portrait_button_onrightclick" {
									onrightclick = "[RightClickMenuManager.ShowForCharacter(Character.AccessSelf)]"
								}
							}
						}
					}
				}


				### BLOC MEMBER 5
				# MEMBER AVAILABLE
				container = {
					tooltipwidget = {
						FancyTooltip_Character = {}
					}
					visible = "[GetPlayer.MakeScope.Var('bpm_sup_ig_4').IsSet]"
					datacontext = "[GetPlayer.MakeScope.Var('bpm_sup_ig_4').GetInterestGroup.GetLeader]"
					parentanchor = hcenter
					position = { 210 15 }
					maximumsize = { 100 265 } # This maximumsize is to make the button for this portrait not overlap the other character's buttons

					character_portrait_base = {
						parentanchor = hcenter

						size = { 250 270 }

						blockoverride "portrait_size" {
							block "character_portrait_size" {
								size = { 265 265 }
							}
						}

						blockoverride "portrait_texture" {
							portrait_texture = "[Character.GetAnimatedPortrait('characters_portrait_environment', 'camera_event_left', 'commander_vs_left', PdxGetWidgetScreenSize(PdxGuiWidget.Self))]"
						}

						blockoverride "portrait_icons" {}
						blockoverride "tooltip" {}
						blockoverride "show_hat" {}
						blockoverride "highlight" {}

						blockoverride "portrait_button" {
							button = {
								parentanchor = hcenter
								size = { 100% 100% }

								block "portrait_button_onclick" {
									onclick = "[InformationPanelBar.OpenCharacterPanel(Character.AccessSelf)]"
								}

								block "portrait_button_onrightclick" {
									onrightclick = "[RightClickMenuManager.ShowForCharacter(Character.AccessSelf)]"
								}
							}
						}
					}
				}


				### BLOC MEMBER 3
				# MEMBER AVAILABLE
				container = {
					tooltipwidget = {
						FancyTooltip_Character = {}
					}
					visible = "[GetPlayer.MakeScope.Var('bpm_sup_ig_2').IsSet]"
					datacontext = "[GetPlayer.MakeScope.Var('bpm_sup_ig_2').GetInterestGroup.GetLeader]"
					parentanchor = hcenter
					position = { 110 15 }
					maximumsize = { 100 265 } # This maximumsize is to make the button for this portrait not overlap the other character's buttons

					character_portrait_base = {
						parentanchor = hcenter

						size = { 250 265 }

						blockoverride "portrait_size" {
							block "character_portrait_size" {
								size = { 280 280 }
							}
						}

						blockoverride "portrait_texture" {
							portrait_texture = "[Character.GetAnimatedPortrait('characters_portrait_environment', 'camera_event_left', 'commander_vs_left', PdxGetWidgetScreenSize(PdxGuiWidget.Self))]"
						}

						blockoverride "portrait_icons" {}
						blockoverride "tooltip" {}
						blockoverride "show_hat" {}
						blockoverride "highlight" {}

						blockoverride "portrait_button" {
							button = {
								parentanchor = hcenter
								size = { 100% 100% }

								block "portrait_button_onclick" {
									onclick = "[InformationPanelBar.OpenCharacterPanel(Character.AccessSelf)]"
								}

								block "portrait_button_onrightclick" {
									onrightclick = "[RightClickMenuManager.ShowForCharacter(Character.AccessSelf)]"
								}
							}
						}
					}
				}


				### BLOC MEMBER 1 (LEADER)
				container = {
					tooltipwidget = {
						FancyTooltip_Character = {}
					}
					visible = "[GetPlayer.MakeScope.Var('bpm_sup_ig_0').IsSet]"
					parentanchor = hcenter
					maximumsize = { 100 265 } # This maximumsize is to make the button for this portrait not overlap the other character's buttons
					datacontext = "[GetPlayer.MakeScope.Var('bpm_sup_ig_0').GetInterestGroup.GetLeader]"

					character_portrait_base = {
						parentanchor = hcenter
						size = { 250 265 }

						blockoverride "portrait_size" {
							block "character_portrait_size" {
								size = { 300 300 }
							}
						}

						blockoverride "portrait_position" {
							position = { 0 15 }
						}

						blockoverride "portrait_texture" {
							portrait_texture = "[Character.GetAnimatedPortrait('pop_environment', 'camera_body', 'commander_vs_left', PdxGetWidgetScreenSize(PdxGuiWidget.Self))]"
						}

						blockoverride "portrait_icons" {}
						blockoverride "tooltip" {}
						blockoverride "show_hat" {}
						blockoverride "highlight" {}

						blockoverride "portrait_button" {
							button = {
								parentanchor = hcenter
								size = { 100% 100% }

								block "portrait_button_onclick" {
									onclick = "[InformationPanelBar.OpenCharacterPanel(Character.AccessSelf)]"
								}

								block "portrait_button_onrightclick" {
									onrightclick = "[RightClickMenuManager.ShowForCharacter(Character.AccessSelf)]"
								}
							}
						}
					}
				}

				vfx = {
					position = { 0 -2 }

					blockoverride "entity_instance" {
						entity_instance = vfx_entity_ui_powerbloc_rank_02_rulers
					}
				}

				character_ig_button = {
					visible = "[GetPlayer.MakeScope.Var('bpm_sup_ig_0').IsSet]"
					size = { 10% 20% }
					datacontext= "[GetPlayer.MakeScope.Var('bpm_sup_ig_0').GetInterestGroup.GetLeader]"
					position = { 0 -20 }
					parentanchor = hcenter|bottom
					blockoverride "in_government_icon" {}
				}

				character_ig_button = {
					visible = "[GetPlayer.MakeScope.Var('bpm_sup_ig_1').IsSet]"
					size = { 5% 10% }
					datacontext= "[GetPlayer.MakeScope.Var('bpm_sup_ig_1').GetInterestGroup.GetLeader]"
					position = { -110 -20 }
					parentanchor = hcenter|bottom
					blockoverride "in_government_icon" {}
				}

				character_ig_button = {
					visible = "[GetPlayer.MakeScope.Var('bpm_sup_ig_2').IsSet]"
					size = { 5% 10% }
					datacontext= "[GetPlayer.MakeScope.Var('bpm_sup_ig_2').GetInterestGroup.GetLeader]"
					position = { 110 -20 }
					parentanchor = hcenter|bottom
					blockoverride "in_government_icon" {}
				}

				character_ig_button = {
					visible = "[GetPlayer.MakeScope.Var('bpm_sup_ig_3').IsSet]"
					size = { 5% 10% }
					datacontext= "[GetPlayer.MakeScope.Var('bpm_sup_ig_3').GetInterestGroup.GetLeader]"
					position = { -210 -20 }
					parentanchor = hcenter|bottom
					blockoverride "in_government_icon" {}
				}

				character_ig_button = {
					visible = "[GetPlayer.MakeScope.Var('bpm_sup_ig_4').IsSet]"
					size = { 5% 10% }
					datacontext= "[GetPlayer.MakeScope.Var('bpm_sup_ig_4').GetInterestGroup.GetLeader]"
					position = { 210 -20 }
					parentanchor = hcenter|bottom
					blockoverride "in_government_icon" {}
				}
			}
			widget = {size = {5 5}}
			hbox = {
				visible = "[NotZero_CFixedPoint(GetPlayer.MakeScope.ScriptValue('bpm_country_strongly_supporting_clout'))]"
				layoutpolicy_horizontal = expanding
				margin_bottom = 2
				margin_left = 30
				spacing = 5

				background = {
					using = default_header_bg
					margin = { 0 5 }

					modify_texture = {
						texture = "gfx/interface/masks/fade_horizontal_center.dds"
						blend_mode = alphamultiply
					}
				}

				icon = {
					parentanchor = hcenter|left
					size = { 28 28 }
					texture = "gfx/interface/icons/generic_icons/approval_icon.dds"
				}

				icon = {
					parentanchor = hcenter|left
					size = { 28 28 }
					texture = "gfx/interface/icons/generic_icons/approval_icon.dds"
				}

				textbox = {
					parentanchor = hcenter|left
					autoresize = yes
					minimumsize = { 253 -1 }
					max_width = 253
					default_format = "#header"
					align = nobaseline
					using = right_click_menu_title_margin_left
					using = elide_fontsize_min
					text = "STRONGLY_SUPPORTING_INTEREST_GROUPS_HEADER"
				}

				expand = {}

				endorsement_info_bar = {
					datacontext = "[GetPlayer.GetLawBeingEnacted]"
					blockoverride "tooltip" {
						using = tooltip_ne
						tooltip = "TOOLTIP_LAW_STRONG_APPROVAL"
					}

					blockoverride "before_bar_icon" {}

					blockoverride "progressbar_size" {
						size = { 150 15 }
					}

					blockoverride "before_bar_text_visibility" {
						visible = no
					}

					blockoverride "above_bar_text_visibility" {
						visible = yes
					}

					blockoverride "above_bar_text_size" {
						size = { 45 20 }
					}

					blockoverride "above_bar_text" {
						text = "LAW_STRONG_APPROVAL"
					}

					blockoverride "bar_value" {
						value = "[GetPlayer.MakeScope.ScriptValue('bpm_country_strongly_supporting_clout')]"
						invertprogress = yes
					}

					blockoverride "marker_visibility" {
						visible = "[NotZero_CFixedPoint(GetPlayer.MakeScope.ScriptValue('bpm_country_strongly_supporting_clout'))]"
					}

					blockoverride "marker_widgetanchor" {
						widgetanchor = left
						mirror = horizontal
					}

					blockoverride "bar_color" {
						using = color_green_approval
					}
				}
				widget = {size = {5 5}}
			}
			vbox = {
				max_width = 556
				layoutpolicy_horizontal = expanding
				datamodel = "[AccessPlayer.AccessAllInterestGroups]"
				item = {
					enactment_interest_group_button = {
						visible = "[GetScriptedGui('enactment_strongly_supporting_ig').IsShown(GuiScope.SetRoot(InterestGroup.MakeScope).End)]"
					}

					negotiate_interest_group_active_widget = {
						visible = "[Or(InterestGroup.HasNegotiated, InterestGroup.IsNegotiating)]"
					}
				}
			}
			widget = {size = {5 5}}
			hbox = {
				visible = "[NotZero_CFixedPoint(GetPlayer.MakeScope.ScriptValue('bpm_country_supporting_clout'))]"
				layoutpolicy_horizontal = expanding
				margin_bottom = 2
				margin_left = 30
				spacing = 5

				background = {
					using = default_header_bg
					margin = { 0 5 }

					modify_texture = {
						texture = "gfx/interface/masks/fade_horizontal_center.dds"
						blend_mode = alphamultiply
					}
				}

				icon = {
					parentanchor = hcenter|left
					size = { 28 28 }
					texture = "gfx/interface/icons/generic_icons/approval_icon.dds"
				}

				textbox = {
					parentanchor = hcenter|left
					autoresize = yes
					minimumsize = { 253 -1 }
					max_width = 253
					default_format = "#header"
					align = nobaseline
					using = right_click_menu_title_margin_left
					using = elide_fontsize_min
					text = "SUPPORTING_INTEREST_GROUPS_HEADER"
				}

				expand = {}

				endorsement_info_bar = {
					datacontext = "[GetPlayer.GetLawBeingEnacted]"
					blockoverride "tooltip" {
						using = tooltip_ne
						tooltip = "TOOLTIP_LAW_APPROVAL"
					}

					blockoverride "before_bar_icon" {}

					blockoverride "progressbar_size" {
						size = { 150 15 }
					}

					blockoverride "before_bar_text_visibility" {
						visible = no
					}

					blockoverride "above_bar_text_visibility" {
						visible = yes
					}

					blockoverride "above_bar_text_size" {
						size = { 45 20 }
					}

					blockoverride "above_bar_text" {
						text = "LAW_APPROVAL"
					}

					blockoverride "bar_value" {
						value = "[GetPlayer.MakeScope.ScriptValue('bpm_country_supporting_clout')]"
						invertprogress = yes
					}

					blockoverride "marker_visibility" {
						visible = "[NotZero_CFixedPoint(GetPlayer.MakeScope.ScriptValue('bpm_country_supporting_clout'))]"
					}

					blockoverride "marker_widgetanchor" {
						widgetanchor = left
						mirror = horizontal
					}

					blockoverride "bar_color" {
						using = color_green_approval
					}
				}
				widget = {size = {5 5}}
			}
			vbox = {
				max_width = 556
				layoutpolicy_horizontal = expanding
				datamodel = "[AccessPlayer.AccessAllInterestGroups]"
				item = {
					enactment_interest_group_button = {
						visible = "[GetScriptedGui('enactment_supporting_ig').IsShown(GuiScope.SetRoot(InterestGroup.MakeScope).End)]"
					}

					negotiate_interest_group_active_widget = {
						visible = "[Or(InterestGroup.HasNegotiated, InterestGroup.IsNegotiating)]"
					}
				}
			}
			expand = {}
		}
		widget = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = preferred
			maximumsize = { 225 320 }
			#visible = "[Not(GameSetup.HasSelectedObjective)]"

			background = {
				texture = "gfx/interface/icons/objectives/hegemon_illu.dds"
				fittype = centercrop
				using = frame_small_mask
			}

			default_header_clean = {
				blockoverride "text" {
					text = "SANDBOX"
				}
