					name = 1
					next = 2
					alpha = 0.3
					duration = 0.5
					using = Animation_Curve_Default
				}
				state = {
					name = 2
					next = 1
					alpha = 1
					duration = 0.5
					using = Animation_Curve_Default
				}
			}
			
			icon = {
				size = { 100% 100% }
				using = frame_small
			}
		}
