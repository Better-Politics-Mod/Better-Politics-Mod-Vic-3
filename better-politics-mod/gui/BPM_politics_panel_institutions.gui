		vbox = {
			visible = "[Not(Or(Country.MakeScope.Var('bpm_cabinet_char_select').IsSet, Country.MakeScope.Var('bpm_cabinet_pm_select').IsSet))]"
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			spacing = 15
			margin = { 10 20 }
			expand = {}
			hbox = {
				spacing = 50
				layoutpolicy_horizontal = expanding
				bpm_cabinet_ministry = { 
					blockoverride "name" {
                        raw_text = "[Concatenate(Localize('bpm_cabinet_mineco'),Concatenate(Concatenate(' (',Localize('bpm_mineco_name_default')),')'))]"
                    }
					blockoverride "not_visible_char" {
                        visible = "[Not(GetPlayer.MakeScope.Var('bpm_mineco').GetCharacter.IsValid)]"
                    }
					blockoverride "visible_char" {
                        visible = "[GetPlayer.MakeScope.Var('bpm_mineco').GetCharacter.IsValid]"
                    }
					blockoverride "character_context" {
                        datacontext = "[GetPlayer.MakeScope.Var('bpm_mineco').GetCharacter]"
                    }
					blockoverride "background_image" {
						texture = "gfx/interface/illustrations/institutions/home_affairs.dds"
                	}
					blockoverride "visible_institution" {
						visible = "[GetScriptedGui('bpm_CAB_mineco_institution').IsShown(GuiScope.SetRoot(Institution.MakeScope).End)]"
					}
					blockoverride "ministry_select" {
						onclick = "[GetScriptedGui('bpm_CAB_mineco_select').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
					}
				}

			}
			hbox = {
				spacing = 50
				layoutpolicy_horizontal = expanding
				bpm_cabinet_ministry = {
					blockoverride "name" {
