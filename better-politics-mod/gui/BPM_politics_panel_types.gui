							}
							size = {65 65}
						}

						icon = {
							datacontext = "[InterestGroup.AccessLeader.GetIdeology]"
							texture = "[Ideology.GetTexture]"
							tooltipwidget = {
								FancyTooltip_Ideology = {}
							}
							size = { 35 35 }
							parentanchor = bottom|right
						}
					}
					
					widget = { size = { 5 5 }}
				}
				bpm_law_sway_menu = {
					visible = "[And(And(Or(Country.IsEnactingLaw, Country.MakeScope.Var('bpm_negotiation_banner_visible').IsSet), Not(InterestGroup.IsMarginal)),GetVariableSystem.Exists(Concatenate('show_law_sways_', InterestGroup.GetName)))]"
				}
			}
			
			block "move_to_opposition_button" {
				button_icon_move_right = {
					visible = "[GetVariableSystem.Exists('reform_government')]"
					layoutpolicy_vertical = expanding
					size = { 35 0 }
					onclick = "[ReformGovernment.UnstageInterestGroup(InterestGroup.AccessSelf)]"
					
					blockoverride "icon_size" {
						size = { 35 90 }
					}
				}
			}
		}
	}

	type unaligned_faction_item = flowcontainer {
		direction = vertical

		datacontext = "[Scope.GetPoliticalMovement]"

		visible = "[GreaterThan_CFixedPoint(InterestGroup.MakeScope.ScriptValue('bpm_unaligned_clout'), '(CFixedPoint)0.01')]"
		layoutpolicy_horizontal = expanding

		margin_bottom = 10

		###NORMAL NON-REVOLUTIONARY MOVEMENT###
		widget = {
			visible = "[Not(PoliticalMovement.IsInsurrectionary)]"
			layoutpolicy_horizontal = expanding
			size = { 745 60 }
			hbox = { 
				layoutpolicy_horizontal = expanding
				margin_left = 95 
				margin_right = 100
				hbox = {
					layoutpolicy_horizontal = expanding
					using = entry_bg_fancy_solid_bg
					minimumsize = { -1 60 }
					maximumsize = { -1 60 }
					expand = { }
					hbox = {
						layoutpolicy_horizontal = expanding
