	type bpm_prime_minister_candidate_entry = hbox {
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = preferred
		minimumsize = { 600 -1 }
		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = preferred
			margin = { 10 10 }
			spacing = 5
	
			using = entry_bg_fancy_solid_bg
			datacontext = "[Scope.GetCharacter]"
			# datacontext = "[Scope.GetCharacter.GetInterestGroup]"
			visible = "[Character.GetInterestGroup.IsValid]"

			background = {
				using = fade_right_entry_fancy_header_colored
				color = "[Character.GetInterestGroup.GetColor]"
			}
	
			character_portrait_large = {
				using = tooltip_below
				blockoverride "show_hat" {}
				blockoverride "highlight" {}
				
				### IG ICON
				character_ig_button = {
					blockoverride "interestgroup_datacontext" {
						datacontext = "[Character.GetInterestGroup]"
					}
					parentanchor = bottom|left
					size = { 38 38 }
					position = { 2 0 }
					blockoverride "in_government_icon" {}
				}
				
				### IDEOLOGY
				icon = {
					parentanchor = bottom|right
					size = { 38 38 }
					position = { -2 0 }
					datacontext = "[Character.GetIdeology]"
					texture = "[Ideology.GetTexture]"
					tooltipwidget = {
						FancyTooltip_Ideology = {}
					}
				}
			}
	
			vbox = {
				layoutpolicy_vertical = expanding
				spacing = 5
	
				textbox = {
					layoutpolicy_horizontal = expanding
					autoresize = yes
					align = left|nobaseline
					elide = right
					using = fontsize_xl
					text = "[Character.GetFullName]"
				}
	
				divider_clean = {
					blockoverride "size" {
						layoutpolicy_horizontal = expanding
						size = { 0 1 }
					}
				}
	
				hbox = {
					margin_left = 5
					layoutpolicy_horizontal = expanding
	
					textbox = {
						autoresize = yes
						minimumsize = { 0 20 }
						align = left|nobaseline
						text = "CHARACTER_POPULARITY_LABEL"
						elide = right
					}
	
					expand = {}
				}
	
				hbox = {
					layoutpolicy_horizontal = expanding
					### TRAITS
					flowcontainer = {
						datamodel = "[Character.AccessTraits]"
						spacing = 2

						item = {
							icon = {
								size = { 25 35 }
								texture = "[CharacterTrait.GetTexture]"
								using = tooltip_above

								tooltipwidget = {
									FancyTooltip_CharacterTrait = {}
								}
							}
						}
					}

					expand = {}
				}
			}
	
			expand = {}
	
			vbox = {
				layoutpolicy_vertical = preferred
				layoutpolicy_horizontal = expanding
	
				expand = {}
	
				hbox = {
					layoutpolicy_horizontal = expanding
	
					expand = {}
	
					button = {
						using = default_button_action
						size = { 150 40 }
						text = "bpm_pm_appoint"
						datacontext = "[Character.GetInteraction('bpm_appoint_pm')]"
						tooltip = "CHARACTER_INTERACTION_TOOLTIP"
						enabled = "[CharacterInteraction.IsCommandValid(Character.Self)]"
						onclick = "[CharacterInteraction.ExecuteCommand(Character.Self)]"
						onclick = "[GetScriptedGui('bpm_CAB_toggle_char_select_off').Execute(GuiScope.SetRoot(Country.MakeScope).End)]"
						# clicksound = "event:/SFX/DLC/1.3_ip1/UI/character_invite"
					}
				}
			}
		}
	}

		### FULLSCREEN WINDOW
	type bpm_fullscreen_block_window = widget {
		filter_mouse = all
		allow_outside = yes
		alwaystransparent = no
		using = sidepanel_plus_sidebar_size
		layoutpolicy_vertical = expanding
		

		widget = {
			size = { 50 100% }
			parentanchor = right
			alwaystransparent = yes
			position = { 20 0 }

			background = {
				texture = "gfx/interface/backgrounds/sidepanel_shadow.dds"
				size = { 100% 100% }
				spriteType = CorneredTiled
				spriteborder_left = 100
				texture_density = 2
				alwaystransparent = yes
				margin_top = 100
			}
		}

		widget = {
			size = { 100% 100% }
			using = clickthrough_blocker

			background = {
				texture = "gfx/interface/backgrounds/sidepanel_filler.dds"
				spriteType = CorneredTiled
				spriteborder = { 0 0 }
				spriteborder_right = 80
				margin_top = 100
				using = clickthrough_blocker

				modify_texture = {
					texture = "gfx/interface/backgrounds/default_bg_shading.dds"
					spriteType = Corneredstretched
					spriteborder = { 0 0 }
					blend_mode = overlay
				}

				modify_texture = {
					using = texture_velvet
				}
				modify_texture = {
					using = fancy_pattern_2
				}
			}
		}
		block "animation_state_block" {}

		state = {
			name = _show
			alpha = 1
			duration = 0
			start_sound = {
				soundeffect = "snapshot:/Dynamic/mute_world_80"
			}
		}
		state = {
			name = _hide
			alpha = 0
			duration = 0.2
			using = Animation_Curve_Default
		}

		vbox = {
			using = sidebar_margin
			layoutpolicy_horizontal = preferred
			layoutpolicy_vertical = expanding

			vbox = {
				using = clickthrough_blocker

				layoutpolicy_vertical = expanding
				layoutpolicy_horizontal = preferred

				background = {
					using = default_bg
					margin_top = -84
				}

				background = {
					spriteType = Corneredtiled
					spriteborder = { 10 0 }
					margin = { 3 0 }
					margin_top = -84
					shaderfile = "gfx/FX/pdxgui_default.shader"
					texture = "gfx/interface/backgrounds/side_frame.dds"
					texture_density = 2

					modify_texture = {
						texture = "gfx/interface/backgrounds/default_bg_shading.dds"
						spriteType = Corneredstretched
						spriteborder = { 0 0 }
						blend_mode = overlay
						alpha = 1
					}
				}

				### HEADER
				block "window_header" {
					widget = {
						size = { @panel_width_plus_20 102 }
						layoutpolicy_horizontal = preferred

						### BG
						widget = {
							size = { @panel_width_plus_30 106 }
							position = { 0 -4 }
							parentanchor = hcenter

							using = sidepanel_top_header
						}

						### TEXT
						block "header_texts" {
							flowcontainer = {
								parentanchor = center

								block "header_texts_before" {}

								textbox = {
									using = header_font_fancy
									using = header_font_fancy_size

									block "window_header_name" {
										raw_text = "Default Window Name"
									}

										align = hcenter|nobaseline

									autoresize = yes

									block "header_texts_maximum_size" {
										maximumsize = { 395 70 }
									}

									multiline = yes
									fontsize_min = 17

									default_format = "#header"
								}
							}
						}

						block "entire_back_button" {
							back_button_large = {
								position = { 8 30 }
								block "header_back_button" {
									onclick = "[InformationPanelBar.OpenPreviousPanel]"
									input_action = "back"
								}
							}
						}

						close_button_large = {
							position = { -8 30 }
							parentanchor = right
							block "header_close_button" {
								onclick = "[InformationPanelBar.ClosePanel]"
							}
							shortcut = "close_window"
						}

						widget = {
							block "pin_visibility" {
								visible = no
							}
							size = { 30 30 }
							position = { -48 59 }
							parentanchor = right

							button_icon_pin = {
								size = { 100% 100% }
								block "pin_properties" {}
								input_action = "toggle_pin"
							}
							button_icon_unpin = {
								size = { 100% 100% }
								block "unpin_properties" {}
								input_action = "toggle_pin"
							}
						}

						widget = {
							block "goto_visibility" {
								visible = no
							}
							size = { 30 30 }
							position = { -48 16 }
							parentanchor = right

							block "custom_goto_button" {
								button_icon_zoom = {
									size = { 100% 100% }
									block "goto_properties" {}
									input_action = "zoom_to"
								}
							}
						}
						
						widget = {
							block "edit_visibility" {
								visible = no
							}
							
							block "edit_tooltip" {
								tooltip = "EDIT"
							}
							
							size = { 30 30 }
							position = { 48 59 }

							button_icon_edit = {
								size = { 100% 100% }
								block "edit_properties" {}
							}
						}

						widget = {
							block "top_left_button_visibility" {
								visible = no
							}
							
							block "top_left_button_tooltip" {}
							
							size = { 30 30 }
							position = { 48 16 }

							button_icon_round = {
								size = { 100% 100% }

								block "top_left_button_properties" {}

								blockoverride "icon" {
									scale = 0.9

									block "top_left_button_texture" {
										texture = "gfx/interface/icons/generic_icons/home_hq.dds"
									}
								}
							}
						}
					}
				}

				block "fixed_top" {
				}

				block "entire_scrollarea" {
					scrollarea = {
						name = "default_block_window_scrollarea"
						layoutpolicy_vertical = preferred
						layoutpolicy_horizontal = preferred

						scrollbarpolicy_horizontal = always_off

						block "scrollarea_backgrounds" {
						}

						scrollbar_vertical = {
							using = vertical_scrollbar
						}

						scrollwidget = {
							block "scrollarea_content_vbox" {
								container = {
									name = "content_container"
									parentanchor = hcenter

									state = {
										name = show
										duration = 0.2
										alpha = 1
										using = Animation_Curve_Default
									}
									state = {
										name = hide
										duration = 0
										alpha = 0
									}

									block "scrollarea_content" {
										widget = {
											size = { @panel_width 1000 }
											background = {
												using = default_background
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
	
	type character_panel_item = widget {
		layoutpolicy_horizontal = expanding
		size = { @panel_width 120 }
		using = entry_bg_fancy
		visible = "[Or(Not(Character.GetInterestGroup.IsValid), GetScriptedGui('bpm_interest_group_visibility').IsShown(GuiScope.SetRoot(Character.GetInterestGroup.MakeScope).End))]"

		tooltipwidget = {
			FancyTooltip_Character = {}
		}

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = preferred
			spacing = 5
			margin_left = 10
			margin_right = 10

			character_portrait_large = {
				using = tooltip_above
				blockoverride "show_hat" {}
				blockoverride "highlight" {}

				### IG ICON
				character_ig_button = {
					parentanchor = bottom|left
					size = { 35 35 }
					position = { 2 0 }
					blockoverride "in_government_icon" {}
				}

				### IDEALOGY
				icon = {
					parentanchor = bottom|right
					size = { 35 35 }
					position = { -2 0 }
					datacontext = "[Character.GetIdeology]"
					texture = "[Ideology.GetTexture]"
					tooltipwidget = {
						FancyTooltip_Ideology = {}
					}
				}
			}

			vbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = preferred
				spacing = 5

				### TITLE + NAME
				hbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = preferred
					margin_top = 10
					spacing = 2

					vbox = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = preferred

						textbox = {
							datacontext = "[Character.GetPrimaryRole]"
							visible = "[CharacterRole.HasDefinedTitles]"
							raw_text = "#b [Character.GetPrimaryRoleTitle]#! #title ([Character.GetPrimaryRole.GetName])#!"
							layoutpolicy_horizontal = expanding
							size = { 0 16 }
							elide = right
							align = left|nobaseline
						}

						textbox = {
							datacontext = "[Character.GetPrimaryRole]"
							visible = "[Not(CharacterRole.HasDefinedTitles)]"
							raw_text = "#title [Character.GetPrimaryRole.GetName]#!"
							layoutpolicy_horizontal = expanding
							size = { 0 16 }
							elide = right
							align = left|nobaseline
						}

						block "additional_info_top_right" {}

						textbox = {
							raw_text = "#BOLD [Character.GetFullNameNoFormatting]#!"
							layoutpolicy_horizontal = expanding
							size = { 0 20 }
							fontsize_min = 14
							elide = right
							align = left|nobaseline
							using = fontsize_large
						}
					}

					### TRAITS
					hbox = {
						layoutpolicy_horizontal = preferred
						spacing = 2
						datamodel = "[Character.AccessTraits]"

						item = {
							icon = {
								size = { 27 38 }
								texture = "[CharacterTrait.GetTexture]"
								alpha = "[TransparentIfTrue(CharacterTrait.IsDisabled)]"
								using = tooltip_se

								tooltipwidget = {
									FancyTooltip_CharacterTrait = {}
								}
							}
						}
					}
				}

				### ICONS
				hbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = preferred
					spacing = 10

					hbox = {
						layoutpolicy_horizontal = expanding
						spacing = 5
						using = tooltip_se
						tooltip = "PROMINENCE_BREAKDOWN"

						icon = {
							size = { 35 35 }

							texture = "gfx/interface/icons/generic_icons/prominence.dds"
						}

						textbox = {
							layoutpolicy_horizontal = expanding
							text = "CHARACTER_PROMINENCE"
							autoresize = yes
							align = left|nobaseline
							elide = right
							minimumsize = { 0 20 }
							#fontsize_min = 14
						}
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						spacing = 5
						using = tooltip_se
						tooltip = "POPULARITY_BREAKDOWN"

						icon = {
							size = { 35 35 }
							texture = "gfx/interface/icons/generic_icons/popularity.dds"
						}

						textbox = {
							layoutpolicy_horizontal = expanding
							text = "CHARACTER_POPULARITY"
							autoresize = yes
							align = left|nobaseline
							elide = right
							minimumsize = { 0 20 }
						}
					}

					widget = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding
					}
				}
			}
		}
	}

	type approval_info2 = widget {
		layoutpolicy_horizontal = expanding
		size = { 0 320 }
		visible = "[Not(Law.IsActive)]"

		vbox = {
			layoutpolicy_horizontal = preferred
			layoutpolicy_vertical = preferred
			margin = { 5 5 }
			visible = "[Or( Not(IsDataModelEmpty(Law.AccessApprovingIGs)), Not(IsDataModelEmpty(Law.AccessDisapprovingIGs))) ]"
			spacing = 10

			hbox = {
				layoutpolicy_horizontal = preferred
				layoutpolicy_vertical = preferred
				margin = { 8 8 }
				spacing = 10
				tooltip = "TOOLTIP_LAW_APPROVAL"
				alpha = "[TransparentIfFalse(NotEqualTo_CFixedPoint( GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('law', Law.MakeScope).ScriptValue('bpm_country_strongly_supporting_clout'), '(CFixedPoint)0' ))]"

				background = {
					using = entry_bg
				}

				icon = {
					size = { 35 35 }
					texture = "gfx/interface/icons/generic_icons/approval_icon.dds"
				}

				icon = {
					size = { 35 35 }
					texture = "gfx/interface/icons/generic_icons/approval_icon.dds"
				}

				flowcontainer = {
					direction = vertical
					spacing = 5

					textbox = {
						align = left|nobaseline
						text = "LAW_STRONG_APPROVAL"
