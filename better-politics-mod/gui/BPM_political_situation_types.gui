@panel_width = 540
@panel_width_minus_10 = 530
@panel_width_minus_20 = 520
@panel_width_minus_40 = 480
@panel_width_plus_10 = 550

types political_situation_types { 
    type bpm_political_situation_dissent_panel = scrollarea {
        layoutpolicy_vertical = preferred
        layoutpolicy_horizontal = preferred

        scrollbarpolicy_horizontal = always_off

        block "scrollarea_backgrounds" {
        }

        scrollbar_vertical = {
            using = vertical_scrollbar
        }
        scrollwidget = {
            block "scrollarea_content_vbox" {
                container = {
                    name = "content_container"
                    parentanchor = hcenter

                    state = {
                        name = show
                        duration = 0.2
                        alpha = 1
                        using = Animation_Curve_Default
                    }
                    state = {
                        name = hide
                        duration = 0
                        alpha = 0
                    }

                    block "scrollarea_content" {
                        vbox = {
                            #max_update_rate = 20
                            #visible = "[GetVariableSystem.Exists('politics_overview_dissent_panel')]"
                            layoutpolicy_horizontal = expanding
                            layoutpolicy_vertical = growing
                            spacing = 10
                            margin = { 0 10 }

                            # hbox = {
                            #     name = "tutorial_highlight_government_title"
                            #     spacing = 5
                            #     margin = { 5 8 }
                            #     layoutpolicy_horizontal = preferred

                            #     background = {
                            #         using = default_header_bg_faded
                            #     }
                                
                            #     textbox = {
                            #         layoutpolicy_horizontal = expanding
                            #         size = { 0 30 }
                            #         raw_text = "Dissent Situation"
                            #         align = hcenter|nobaseline
                            #         elide = right
                            #         using = fontsize_xxl
                            #         margin_left = 5
                            #     }



                            # }
                            top_illu = {
                                datacontext = "[AccessPlayer]"
                                blockoverride "illu" {
                                    texture = "gfx/interface/illustrations/top_illus/top_illu_companies.dds"
                                }

                                size = { @panel_width_plus_10 120 }

                                flowcontainer = {
                                    direction = vertical
                                    parentanchor = center

                                    textbox = {	
                                        margin_top = 2			
                                        text = "bpm_political_situation_dissent_header"
                                        using = fontsize_xl
                                        using = companies_header_texts
                                    }

                                    textbox = {				
                                        text = "bpm_political_situation_dissent_crises_active"
                                        using = companies_header_texts
                                    }

                                    textbox = {
                                        text = "bpm_political_situation_dissent_crises_preparing"
                                        using = companies_header_texts
                                    }

                                    textbox = {				
                                        text = "bpm_political_situation_dissent_crises_inactive"
                                        using = companies_header_texts
                                    }

                                }
                            }


                            vbox = {
                                default_header_2texts = {
                                    blockoverride "text1" {
                                        text = "bpm_dissent_actions_header"
                                    }
                                    blockoverride "text2" {
                                        text = "bpm_dissent_actions_active_v_potential"
                                    }
                                }
                                flowcontainer = {
                                    #parentanchor = hcenter
                                    direction = horizontal
                                    spacing = 10

                                    spacing = 10
                                    margin = { 10 10 }

                                    datamodel = "[AccessPlayer.GetGroupsForActiveJournalEntries]"

                                    #visible = "Not(IsDataModelEmpty(GetJournalEntryGroup('je_group_bpm_dissent').GetInactiveJournalEntryTypes(GetPlayer.Self)))"
                                    item = {
                                        flowcontainer = {
                                            max_update_rate = 20
                                            spacing = 10
                                            #parentanchor = hcenter
                                            visible = "[ObjectsEqual(MakeScopeFlag(GetJournalEntryGroup('je_group_bpm_dissent').GetName), MakeScopeFlag(JournalEntryGroup.GetName))]"
                                            datamodel = "[JournalEntryGroup.GetActiveJournalEntryTypes(GetPlayer.Self)]"
                                            direction = vertical
                                            item = {
                                                bpm_political_situation_subversive_actions = { }
                                            }
                                        }
                                    }
                                }

                                hbox = {
                                    minimumsize = { -1 40}
                                }

                                section_header_button = {
                                    blockoverride "left_text" {
                                        text = "bpm_potential_preparing_actions"
                                    }

                                    blockoverride "right_text" {
                                        section_header_right_text = {
                                            text = "bpm_dissent_actions_preparing_count"
                                        }
                                    }
                                    blockoverride "onclick" {
                                        onclick = "[GetVariableSystem.Toggle('bpm_preparing_dissent_actions')]"
                                    }
                                    
                                    blockoverride "onclick_showmore" {
                                        visible = "[Not(GetVariableSystem.Exists('bpm_preparing_dissent_actions'))]"
                                    }

                                    blockoverride "onclick_showless" {
                                        visible = "[GetVariableSystem.Exists('bpm_preparing_dissent_actions')]"
                                    }
                                }


                                flowcontainer = {
                                    #parentanchor = hcenter
                                    direction = horizontal
                                    margin = { 10 0 }

                                    datamodel = "[AccessPlayer.GetGroupsForInActiveJournalEntries]"

                                    visible = "[GetVariableSystem.Exists('bpm_preparing_dissent_actions')]"

                                    #visible = "Not(IsDataModelEmpty(GetJournalEntryGroup('je_group_bpm_dissent').GetInactiveJournalEntryTypes(GetPlayer.Self)))"
                                    item = {
                                        flowcontainer = {
                                            max_update_rate = 20
                                            spacing = 4
                                            #parentanchor = hcenter
                                            visible = "[ObjectsEqual(MakeScopeFlag(GetJournalEntryGroup('je_group_bpm_dissent').GetName), MakeScopeFlag(JournalEntryGroup.GetName))]"
                                            datamodel = "[JournalEntryGroup.GetInactiveJournalEntryTypes(GetPlayer.Self)]"
                                            #datamodel = "[GetJournalEntryGroup('je_group_bpm_dissent').GetInactiveJournalEntryTypes(GetPlayer.Self)]"
                                            direction = vertical
                                            item = {
                                                bpm_political_situation_subversive_actions_preparing = {}
                                            }
                                        }
                                    }
                                    expand = {}
                                }
                                section_header_button = {
                                    blockoverride "left_text" {
                                        text = "bpm_potential_potential_actions"
                                    }

                                    blockoverride "right_text" {
                                        section_header_right_text = {
                                            text = "bpm_dissent_actions_potential_count"
                                        }
                                    }
                                    blockoverride "onclick" {
                                        onclick = "[GetVariableSystem.Toggle('bpm_potential_dissent_actions')]"
                                    }
                                    
                                    blockoverride "onclick_showmore" {
                                        visible = "[Not(GetVariableSystem.Exists('bpm_potential_dissent_actions'))]"
                                    }

                                    blockoverride "onclick_showless" {
                                        visible = "[GetVariableSystem.Exists('bpm_potential_dissent_actions')]"
                                    }
                                }


                                flowcontainer = {
                                    #parentanchor = hcenter
                                    direction = horizontal
                                    margin = { 10 0 }

                                    datamodel = "[AccessPlayer.GetGroupsForInActiveJournalEntries]"

                                    visible = "[GetVariableSystem.Exists('bpm_potential_dissent_actions')]"

                                    #visible = "Not(IsDataModelEmpty(GetJournalEntryGroup('je_group_bpm_dissent').GetInactiveJournalEntryTypes(GetPlayer.Self)))"
                                    item = {
                                        flowcontainer = {
                                            max_update_rate = 20
                                            spacing = 4
                                            #parentanchor = hcenter
                                            visible = "[ObjectsEqual(MakeScopeFlag(GetJournalEntryGroup('je_group_bpm_dissent').GetName), MakeScopeFlag(JournalEntryGroup.GetName))]"
                                            datamodel = "[JournalEntryGroup.GetInactiveJournalEntryTypes(GetPlayer.Self)]"
                                            #datamodel = "[GetJournalEntryGroup('je_group_bpm_dissent').GetInactiveJournalEntryTypes(GetPlayer.Self)]"
                                            direction = vertical
                                            item = {
                                                bpm_political_situation_subversive_actions_potential = {}
                                            }
                                        }
                                    }
                                    expand = {}
                                }
                                expand = {}
                            }

                            expand = {}
                        }
                    }
                }
            }
        }
    }
    type bpm_political_situation_crises_panel = scrollarea {
        layoutpolicy_vertical = preferred
        layoutpolicy_horizontal = preferred

        scrollbarpolicy_horizontal = always_off

        block "scrollarea_backgrounds" {
        }

        scrollbar_vertical = {
            using = vertical_scrollbar
        }
        scrollwidget = {
            block "scrollarea_content_vbox" {
                container = {
                    name = "content_container"
                    parentanchor = hcenter

                    state = {
                        name = show
                        duration = 0.2
                        alpha = 1
                        using = Animation_Curve_Default
                    }
                    state = {
                        name = hide
                        duration = 0
                        alpha = 0
                    }

                    block "scrollarea_content" {
                        vbox = {
                            #max_update_rate = 20
                            #visible = "[GetVariableSystem.Exists('politics_overview_dissent_panel')]"
                            layoutpolicy_horizontal = expanding
                            layoutpolicy_vertical = growing
                            spacing = 10
                            margin = { 0 10 }

                            # hbox = {
                            #     name = "tutorial_highlight_government_title"
                            #     spacing = 5
                            #     margin = { 5 8 }
                            #     layoutpolicy_horizontal = preferred

                            #     background = {
                            #         using = default_header_bg_faded
                            #     }
                                
                            #     textbox = {
                            #         layoutpolicy_horizontal = expanding
                            #         size = { 0 30 }
                            #         raw_text = "Dissent Situation"
                            #         align = hcenter|nobaseline
                            #         elide = right
                            #         using = fontsize_xxl
                            #         margin_left = 5
                            #     }



                            # }
                            top_illu = {
                                datacontext = "[AccessPlayer]"
                                blockoverride "illu" {
                                    texture = "gfx/interface/illustrations/top_illus/top_illu_companies.dds"
                                }

                                size = { @panel_width_plus_10 120 }

                                flowcontainer = {
                                    direction = vertical
                                    parentanchor = center

                                    textbox = {	
                                        margin_top = 2			
                                        text = "bpm_political_situation_crisis_header"
                                        using = fontsize_xl
                                        using = companies_header_texts
                                    }

                                    textbox = {				
                                        text = "bpm_preparedness_overall_text"
                                        using = companies_header_texts
                                    }

                                    textbox = {
                                        text = "bpm_political_situation_dissent_crises_preparing"
                                        using = companies_header_texts
                                    }

                                    textbox = {				
                                        text = "bpm_political_situation_dissent_crises_inactive"
                                        using = companies_header_texts
                                    }

                                }
                            }


                            vbox = {
                                default_header_2texts = {
                                    blockoverride "text1" {
                                        text = "bpm_crisis_actions_header"
                                    }
                                    blockoverride "text2" {
                                        text = "bpm_crisis_actions_header_active"
                                    }
                                }
                                flowcontainer = {
                                    #parentanchor = hcenter
                                    direction = horizontal
                                    margin = { 10 10 }

                                    datamodel = "[AccessPlayer.GetGroupsForActiveJournalEntries]"

                                    #visible = "Not(IsDataModelEmpty(GetJournalEntryGroup('je_group_bpm_dissent').GetInactiveJournalEntryTypes(GetPlayer.Self)))"
                                    item = {
                                        flowcontainer = {
                                            spacing = 4
                                            #parentanchor = hcenter
                                            visible = "[ObjectsEqual(MakeScopeFlag(GetJournalEntryGroup('je_group_bpm_crises').GetName), MakeScopeFlag(JournalEntryGroup.GetName))]"
                                            datamodel = "[JournalEntryGroup.GetActiveJournalEntryTypes(GetPlayer.Self)]"
                                            direction = vertical
                                            item = {
                                                bpm_political_situation_crises_scandals = { }
                                            }
                                        }
                                    }
                                }

                                hbox = {
                                    minimumsize = { -1 40}
                                }
                                section_header_button = {
                                    blockoverride "left_text" {
                                        text = "bpm_potential_potential_actions_crises"
                                    }

                                    blockoverride "right_text" {
                                        section_header_right_text = {
                                            text = "bpm_potential_potential_actions_crises_count"
                                        }
                                    }
                                    blockoverride "onclick" {
                                        onclick = "[GetVariableSystem.Toggle('bpm_potential_crises_actions')]"
                                    }
                                    
                                    blockoverride "onclick_showmore" {
                                        visible = "[Not(GetVariableSystem.Exists('bpm_potential_crises_actions'))]"
                                    }

                                    blockoverride "onclick_showless" {
                                        visible = "[GetVariableSystem.Exists('bpm_potential_crises_actions')]"
                                    }
                                }


                                flowcontainer = {
                                    #parentanchor = hcenter
                                    direction = horizontal
                                    margin = { 10 10 }

                                    datamodel = "[AccessPlayer.GetGroupsForInActiveJournalEntries]"

                                    visible = "[GetVariableSystem.Exists('bpm_potential_crises_actions')]"
                                    item = {
                                        flowcontainer = {
                                            spacing = 4
                                            #parentanchor = hcenter
                                            visible = "[ObjectsEqual(MakeScopeFlag(GetJournalEntryGroup('je_group_bpm_crises').GetName), MakeScopeFlag(JournalEntryGroup.GetName))]"
                                            datamodel = "[JournalEntryGroup.GetInactiveJournalEntryTypes(GetPlayer.Self)]"
                                            #datamodel = "[GetJournalEntryGroup('je_group_bpm_dissent').GetInactiveJournalEntryTypes(GetPlayer.Self)]"
                                            direction = vertical
                                            item = {
                                                bpm_political_situation_crises_scandals = {
                                                    blockoverride "msz" {
                                                        size = { 475 140 }
                                                    }
                                                    blockoverride "msz1" {
                                                        maximumsize = { 475 120 }
                                                    }
                                                 }
                                            }
                                        }
                                    }
                                    expand = {}
                                }
                                expand = {}
                            }

                            expand = {}
                        }
                    }
                }
            }
        }
    }
