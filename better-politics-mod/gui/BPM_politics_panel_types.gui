	type bpm_levels_progressbar = hbox {
		layoutpolicy_horizontal = expanding
		spacing = 3
		
		background = {
			texture = "gfx/interface/progressbar/progressbar_empty.dds"
			spriteType = Corneredtiled
			spriteborder = { 4 4 }
			texture_density = 2
			alpha = 0.8
			
			using = progressbar_texture_properties
		}
		
		background = {
			texture = "gfx/interface/progressbar/progressbar_frame.dds"
			spriteType = Corneredstretched
			spriteborder = { 6 6 }
			texture_density = 2
			margin = { 3 3 }
		}
		
		item = {
			widget = {
				size = { 0 15 }
				layoutpolicy_horizontal = expanding
				block "item_properties" {}
				using = tooltip_se
				datacontext = "[Scope]"
				
				# active background
				widget = {
					size = { 100% 100% }
					block "level_active" {}

					background = {
						using = dark_area
						alpha = 0.4
					}
				}

				# progress default
				block "progressbar_type" {
					white_progressbar_horizontal = {
						block "default_progressbar_visible" {
							visible = yes
						}
						size = { 100% 100% }
						blockoverride "background" {}
						blockoverride "frame" {}
						blockoverride "glow_visible" {
							block "level_active" {}
						}

						blockoverride "values" {
							block "default_progressbar_value" {}
							min = 0
							max = 1
						}
					}
				}
				
				# progress predicted value (will increase)
				changed_value_increased_progressbar_horizontal_white = {
					block "will_increase_visible" {
						visible = no
					}
					size = { 100% 100% }
					blockoverride "background" {}
					blockoverride "frame" {}
					blockoverride "glow_visible" {
						block "level_active" {}
					}
				}
				
				# progress predicted value (will decrease)
				changed_value_decreased_progressbar_horizontal_white = {
					block "will_decrease_visible" {
						visible = no
					}
					
					size = { 100% 100% }
					blockoverride "background" {}
					blockoverride "frame" {}
					blockoverride "glow_visible" {
						block "level_active" {}
					}
				}
				
				# divider between levels
				widget = {
					block "last_level" {}
					size = { 3 100% }
					position = { 3 0 }
					parentanchor = right
					
					background = {
						margin = { 0 1 }
						texture = "gfx/interface/progressbar/progressbar_center_divider.dds"
						spriteType = Corneredstretched
						spriteborder = { 0 0 }
						texture_density = 2
					}
				}
				
				# active indicator
				widget = {
					size = { 100% 100% }
					block "level_active" {}
					block "level_predicted" {}

					icon = {
						size = { 100% 100% }
						texture = "gfx/interface/progressbar/progressbar_active_level.dds"
						spriteType = Corneredstretched
						spriteborder = { 6 6 }
						texture_density = 2
						
						using = shimmer
					}
				}
			}
		}
	}


	type politics_panel_state_capacity = widget { 
		size = { 360 40 }
		vbox = {
			layoutpolicy_horizontal = expanding
			spacing = 4
			expand = {}
			margin_top = 10
			hbox = {
				layoutpolicy_horizontal = expanding
				spacing = 10
				tooltip = "bpm_state_capacity_tooltip"
				expand = {}
					textbox = {
						autoresize = yes
						raw_text = "#gold;bold [Country.GetCustom('bpm_auth_state_capacity_level')]#!"
						align = nobaseline
					}
					textbox = {
						autoresize = yes
						size = { 0 20 }
						raw_text = "( #variable [GetPlayer.MakeScope.ScriptValue('bpm_state_capacity')|d1] #! @arrow_right! #variable [GetPlayer.MakeScope.ScriptValue('bpm_state_capacity_target')|d1] #!)"
						align = nobaseline
					}
					textbox = {
						size = { 0 20 }
						autoresize = yes
						raw_text = "(#variable [GetPlayer.MakeScope.ScriptValue('bpm_state_capacity_trend_signed')|+=d1] #!/week)"
						align = nobaseline
					}
					expand = {}
			}
			bpm_levels_progressbar = {
				datamodel = "[GetGlobalList('bpm_sc_levels')]"
				
				blockoverride "item_properties" {
					layoutstretchfactor_horizontal = 1000
					tooltip = "test"
				}
				blockoverride "level_active" {
					visible = no
					#visible = "[GetScriptedGui(Concatenate('bpm_sc_level_active_', Scope.GetFlagName)).IsShown(GuiScope.SetRoot(Country).End)]"
				}
				blockoverride "last_level" {
					#datacontext = "[SCOPE]"
					visible = "[Not(EqualTo_string( Scope.GetFlagName, 'lv4' ))]"
				}
				blockoverride "default_progressbar_visible" {
					visible = "[EqualTo_CFixedPoint( GetPlayer.MakeScope.ScriptValue('bpm_state_capacity_trend_signed'), '(CFixedPoint)0' )]"
				}
				blockoverride "will_increase_visible" {
					visible = "[GreaterThan_CFixedPoint( GetPlayer.MakeScope.ScriptValue('bpm_state_capacity_trend_signed'), '(CFixedPoint)0' )]"
				}
				blockoverride "will_decrease_visible" {
					visible = "[LessThan_CFixedPoint( GetPlayer.MakeScope.ScriptValue('bpm_state_capacity_trend_signed'), '(CFixedPoint)0' )]"
				}
				blockoverride "default_progressbar_value" {
					value = "[GetPlayer.MakeScope.ScriptValue(Concatenate('bpm_state_capacity_', Scope.GetFlagName))]"
				}
				blockoverride "new_value" {
					value = "[GetPlayer.MakeScope.ScriptValue(Concatenate('bpm_state_capacity_target_', Scope.GetFlagName))]"
				}
				blockoverride "start_value" {
					value = "[GetPlayer.MakeScope.ScriptValue(Concatenate('bpm_state_capacity_', Scope.GetFlagName))]"
				}
				blockoverride "level_predicted" {
					using = look_at_me_animation
				}
			}

			# white_progressbar_horizontal = {
			# 	name = "bpm_state_capacity_progressbar"
			# 	layoutpolicy_horizontal = expanding
			# 	size = { 15 15 }
			# 	tooltip = "bpm_state_capacity_tooltip"
			# 	blockoverride "values" {
			# 		value = "[Country.MakeScope.ScriptValue('bpm_state_capacity')]"
			# 		min = 0
			# 		max = 100
			# 	}
			# }
			expand = {}
		}
	}

