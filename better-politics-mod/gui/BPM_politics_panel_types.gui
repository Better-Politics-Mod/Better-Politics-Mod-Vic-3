						layoutpolicy_horizontal = preferred
						align = nobaseline
						size = { 0 30 }
						elide = right
						margin_bottom = 5
						using = tooltip_se
						text = "ACTIVE_LAW_AMENDMENTS_TEXT"

						tooltipwidget = {
							RegularTooltip_AmendmentsList = {}
						}
					}
					
					# approval_info_small2 = {
					# 	layoutpolicy_horizontal = preferred

					# 	name = "approval_info"
