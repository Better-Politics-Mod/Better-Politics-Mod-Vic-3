						min_width = 550
						max_width = 550
					}
				}

				textbox = {
					visible = "[Not(StringIsEmpty(Amendment.GetType.GetUnlocks))]"
					autoresize = yes
					align = nobaseline
					multiline = yes
					text = "[Amendment.GetType.GetUnlocks]"

					block "effects_min_max_widths" {
						min_width = 550
						max_width = 550
					}
				}

				textbox = {
