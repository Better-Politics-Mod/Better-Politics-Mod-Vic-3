			}

			icon = {
				datacontext = "[Amendment.GetParentLawType]"
				size = { 30 30 }
				texture = "[LawType.GetTexture]"
			}

			textbox = {
				autoresize = yes
				align = hcenter|nobaseline
				fontsize_min = 14
				elide = right
				text = "[Amendment.GetNameNoFormatting]"
			}

			icon = {
				datacontext = "[Amendment.GetSponsor]"
				size = { 30 30 }
				texture = "[InterestGroup.GetTexture]"
			}

			expand = {}

			textbox = {
				autoresize = yes
				align = hcenter|nobaseline
				elide = right
				using = fontsize_small
				text = "[concept_amendment]"
			}

			widget = {
				size = { 5 5 }
			}

			button_icon_cancel = {
				size = { 30 30 }
				enabled = "[GetScriptedGui('bpm_repeal_amendment_confirmation_gui').IsValid(GuiScope.SetRoot(Country.MakeScope).AddScope('at', Amendment.MakeScope).End)]"
				onclick = "[GetScriptedGui('bpm_repeal_amendment_confirmation_gui').Execute(GuiScope.SetRoot(Country.MakeScope).AddScope('at', Amendment.MakeScope).End)]"
				onclick = "[InformationPanelBar.OpenPanelTab( 'politics', 'interest_groups' )]"
				using = close_button_sound
				tooltip = "BPM_REPEAL_AMENDMENT"
			}
		}

		vbox = {
			layoutpolicy_horizontal = expanding
			margin = { 3 0 }
			margin_bottom = 3

			section_header_button = {
				block "section_header_visiblity" {
					visible = no
				}

				blockoverride "layout" {
					layoutpolicy_horizontal = expanding
					size = { 0 34 }
				}

				blockoverride "arrow_position" {
					position = { 5 0 }
					parentanchor = vcenter
				}

				blockoverride "background" {
					using = expand_button_bg_no_fade
				}

				blockoverride "left_text" {
					text = "AMENDMENT_EFFECTS_AND_MODIFIERS"
				}

				blockoverride "fontsize" {}

				blockoverride "onclick" {
					onclick = "[GetVariableSystem.Toggle( Concatenate(Amendment.GetName, '_amendment_effects') )]"
				}

				blockoverride "onclick_showmore" {
					visible = "[GetVariableSystem.Exists( Concatenate(Amendment.GetName, '_amendment_effects') )]"
				}

				blockoverride "onclick_showless" {
					visible = "[Not(GetVariableSystem.Exists( Concatenate(Amendment.GetName, '_amendment_effects') ))]"
				}
			}

			vbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				margin = { 7 5 }
				margin_bottom = 7

				block "effects_and_modifiers_visibility" {
					visible = no
				}

				textbox = {
					visible = "[Not(StringIsEmpty(Amendment.GetType.GetSponsorModifier.GetDesc))]"
