			datacontext = "[GetPlayer]"
			visible = "[And(Country.MakeScope.Var('bpm_has_cabinet').IsSet, Country.MakeScope.Var('bpm_headofgov').GetCharacter.IsValid)]"
			datacontext = "[GetPlayer.MakeScope.Var('bpm_headofgov')]"
			datacontext = "[Scope.GetCharacter]"
			layoutpolicy_horizontal = expanding
			spacing = 5

			vbox = {
				minimumsize = { 500 -1 }
				maximumsize = { 500 -1 }
				politics_panel_hog_item = {
					blockoverride "banner" { 
						widget = {
							layoutpolicy_horizontal = preferred
							size = { 0 38 }
				
							background = {
								using = default_header_bg
								using = frame_small_mask_top
							}
				
							textbox = {
								text = bpm_hog_panel_name
								size = { 100% 100% }
								align = center|nobaseline
								using = fontsize_large
								default_format = "#title"
								elide = right
							}
						}
					}
				}
			}

			vbox = {
				# margin = { 10 20 }

