	type enactment_interest_group_button = button {
		using = default_button
		enabled = "[IsValid(GetPlayer.StartNegotiationWith(InterestGroup.Self))]"
		#onclick = "[Execute(Country.StartNegotiationWith(InterestGroup.Self))]"

		block "size" {
			size = { 556 44 }
		}

		#tooltipwidget = {
		#	FancyTooltip_IG = {
		#	}
		#}

		tooltip = "INTEREST_GROUP_LAW_SUPPORT_FACTORS_TT"

		#color = "[InterestGroup.GetColor]"

		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			margin = { 10 0 }
			spacing = 5

			icon = {
				size = { 28 28 }
				texture = "[InterestGroup.GetTexture]"
			}

			### NAME
			textbox = {
				size = { 180 30 }
				align = nobaseline
				using = elide_fontsize_min
				using = fontsize_large
				text = "[InterestGroup.GetNameNoFormatting]"
			}

			hbox = {
				spacing = 4

				icon = {
					size = { 24 24 }
					texture = "gfx/interface/icons/generic_icons/amenability.dds"
				}

				textbox = {
					autoresize = yes
					align = nobaseline
					#using = elide_fontsize_min
					max_width = 80
					raw_text = "#tooltippable #tooltip:[InterestGroup.GetTooltipTag],INTEREST_GROUP_AMENABILITY_FACTORS_TT [InterestGroup.GetAmenabilityLabel]#!#!"
				}
			}

			expand = {}

			### CLOUT
			vbox = {
				layoutpolicy_vertical = preferred

				expand = {}

				textbox = {
					layoutpolicy_horizontal = preferred
					size = { 0 20 }
					align = right|nobaseline
					margin_right = 2
					raw_text = "#b [InterestGroup.GetClout|%1]#!"
				}

				bar_horizontal = {
					size = { 150 10 }

					blockoverride "values" {
						min = 0
						max = 1
						value = "[FixedPointToFloat(InterestGroup.GetClout)]"
						invertprogress = yes
					}

					blockoverride "marker_widgetanchor" {
						widgetanchor = left
						mirror = horizontal
					}

					blockoverride "color" {
						color = "[InterestGroup.GetColor]"
					}
				}

				expand = {}
			}
		}
	}

	type enactment_ig_item = vbox {
		max_height = 73
		layoutpolicy_horizontal = expanding
		layoutpolicy_vertical = preferred
		block "visible" {
			visible = "[Or( GreaterThanOrEqualTo_CFixedPoint(InterestGroup.GetClout,'(CFixedPoint)0.001'), InterestGroup.IsInGovernment )]"
		}
		background = {
			texture = "gfx/interface/masks/fade_horizontal_center.dds"
			color = "[InterestGroup.GetColor]"
			alpha = 0.3

			modify_texture = {
				using = texture_velvet
			}
		}
		
		divider_clean = {
			size = { 0 2 }
			layoutpolicy_horizontal = expanding
		}
		
		hbox = {
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = preferred
			
			vbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = preferred
				hbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = preferred
					spacing = 2
					margin_bottom = 2
					minimumsize = { -1 35 }

					### IG BUTTON
					widget = {
						size = { 45 30 }
						ig_button = {
							block "ig_button_size" {
								size = { 30 30 }
							}
							using = tooltip_ws
							parentanchor = hcenter|vcenter
							blockoverride "in_government_icon" {}
						}
					}

					### CENTER INFO


						### HEADER ( icons / name / clout )


							

							### NAME
							textbox = {
								#layoutpolicy_horizontal = expanding
								size = { 0 30 }
								raw_text = "#v  [InterestGroup.GetNameNoFormatting]#! "
								align = left|nobaseline
								autoresize = yes
								using = fontsize_large
								block "highlight_name" {}
								elide = right
								min_width = 200
							}

							### LAW SUPPORT
							textbox = {
								visible = "[Not(GreaterThanOrEqualTo_CFixedPoint(InterestGroup.MakeScope.ScriptValue('bpm_ig_law_support_total_value'), '(CFixedPoint)2'))]"
								margin_left = 5
								autoresize = yes
								align = center
								text = "INTEREST_GROUP_AMENABILITY"
							}

							textbox = {
								visible = "[GreaterThanOrEqualTo_CFixedPoint(InterestGroup.MakeScope.ScriptValue('bpm_ig_law_support_total_value'), '(CFixedPoint)2')]"
								margin_left = 1
								autoresize = yes
								align = center
								text = "INTEREST_GROUP_CONCESSIVENESS"
							}

								
								expand = {}
								
								textbox = {
									minimumsize = {62 20}
									tooltip = "bpm_ig_law_support_tooltip"
									background = {
									using = simple_frame
								}
								background = {
									using = dark_area
								}
									align = right|nobaseline
									tooltip = "bpm_ig_law_support_tooltip"
									raw_text = "[InterestGroup.GetCustom('bpm_ig_enactment_stance_loc')] "
								}

								widget = { size = { 5 5 }}
							vertical_divider_full = {}
							vbox = {
								layoutpolicy_vertical = preferred
								spacing = 0
								hbox = {
	
									using = clout_tooltip_with_graph
									icon = {
										texture = "gfx/interface/icons/generic_icons/government_building_icon.dds"
										size = { 20 20 }
									}
									textbox = {
										size = { 54 20 }
										align = right|nobaseline
										text = "[InterestGroup.GetClout|%1]"
										default_format = "#variable"
										using = fontsize_large
									}
								}
								bar_horizontal = {
									size = { 75 10 }

									blockoverride "values" {
										min = 0
										max = "[AccessPlayer.GetMaxCloutOrPopulationPercentage]"
										value = "[FixedPointToFloat(InterestGroup.GetClout)]"
										invertprogress = yes
									}
									blockoverride "marker_widgetanchor" {
										widgetanchor = left
										mirror = horizontal
									}
									blockoverride "color" {
										color = "[InterestGroup.GetColor]"
									}
								}
							}
					
					
					widget = { size = { 5 5 }}
				}
			}
		}
	}
}